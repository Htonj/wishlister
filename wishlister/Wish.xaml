<UserControl x:Class="wishlister.Wish"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:wishlister"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="400" Background="#323232" Margin="0,2">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="AUTO"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="AUTO"></RowDefinition>
        </Grid.RowDefinitions>
        <Label FontFamily="Lucida Console" Name="namexD" FontWeight="Bold" Foreground="White" Margin="5" FontSize="25">TESTTSS</Label>
        <Label FontFamily="Lucida Console" Name="price" Grid.Column="1" Margin="5" HorizontalAlignment="Right" FontSize="15" Foreground="White"></Label>
        <Button Grid.Column="2" BorderThickness="0" Background="HotPink" Width="40" Margin="2" FontSize="15" Foreground="White">+</Button>
        <ProgressBar Grid.Row="2" Grid.ColumnSpan="3" Background="#212121" Height="5" BorderThickness="0" Foreground="HotPink"></ProgressBar>
    </Grid>
</UserControl>
