<Window x:Class="wishlister.Adder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wishlister"
        mc:Ignorable="d"
        Title="Adder" Height="150" Width="300" Background="#212121" Closing="OnClose">
    <StackPanel>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Label FontFamily="Lucida Console" Name="price" Margin="5" FontSize="15" Foreground="White">Enter name: </Label>
        <Label FontFamily="Lucida Console" Grid.Row="1" Name="name" Margin="5" FontSize="15" Foreground="White">Enter price: </Label>
        <TextBox x:Name="NameBox" Grid.Column="1" BorderThickness="0" Margin="5" Background="#FF323232" Foreground="White"></TextBox>
        <TextBox x:Name="PriceBox" Grid.Column="1" Grid.Row="1" BorderThickness="0" Margin="5" Background="#FF323232" Foreground="White"></TextBox>
    </Grid>
        <Button Background="#FFF50748" Foreground="White" BorderThickness="0" Height="25" Margin="5" Width="120" Click="Button_Click">Add</Button>
    </StackPanel>
</Window>
